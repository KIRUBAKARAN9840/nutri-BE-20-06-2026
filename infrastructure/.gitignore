# Terraform state files (NEVER commit these)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Local .terraform directories
**/.terraform/*
**/.terraform.lock.hcl

# Sensitive variable files — only commit terraform.tfvars (no secrets in it)
*.auto.tfvars
*.auto.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Generated config (after `terraform plan -generate-config-out`)
generated/
generated.tf

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
